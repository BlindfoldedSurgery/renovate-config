{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":configMigration",
    ":enablePreCommit",
    ":semanticCommits",
    "abandonments:recommended",
    "github>blindfoldedsurgery/renovate-config:pub",
    "github>blindfoldedsurgery/renovate-config:python",
    "customManagers:dockerfileVersions",
    "customManagers:githubActionsVersions",
    "customManagers:helmChartYamlAppVersions",
    "helpers:pinGitHubActionDigests"
  ],
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "rangeStrategy": "pin",
  "prHourlyLimit": 0,
  "automergeStrategy": "rebase",
  "separateMinorPatch": true,
  "configMigration": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "after 17:00 on friday"
    ],
    "automerge": true
  },
  "rollbackPrs": true,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "matchDepTypes": [
        "dev-dependencies",
        "dev_dependencies",
        "dev"
      ],
      "automerge": true
    },
    {
      "groupName": "Terraform",
      "description": "Group terraform asdf and terraform-internal updates",
      "matchDepNames": [
        "hashicorp/terraform",
        "terraform"
      ],
      "matchManagers": [
        "asdf",
        "mise",
        "github-actions",
        "terraform"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackagePrefixes": [
        "docker/"
      ],
      "groupName": "GitHub Actions by Docker"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "matchPackageNames": [
        "actions/upload-artifact",
        "actions/download-artifact"
      ],
      "groupName": "artifact actions"
    },
    {
      "matchDepNames": [
        "bun",
        "oven/bun",
        "docker.io/oven/bun"
      ],
      "groupName": "bun"
    },
    {
      "matchDepNames": [
        "uv",
        "ghcr.io/astral-sh/uv",
        "uv_build"
      ],
      "groupName": "uv"
    },
    {
      "matchDepNames": [
        "helmfile"
      ],
      "matchPackagePrefixes": [
        "ghcr.io/helmfile/helmfile"
      ],
      "groupName": "Helmfile"
    },
    {
      "groupName": "commitizen",
      "matchDepNames": [
        "commitizen",
        "commitizen-tools/commitizen"
      ],
      "semanticCommitType": "ci",
      "rangeStrategy": "pin"
    },
    {
      "matchCategories": [
        "terraform"
      ],
      "matchDepNames": [
        "github.com/BlindfoldedSurgery/terraform-repo-module",
        "github"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "GitHub"
    },
    {
      "matchPackageNames": [
        "dflook/terraform-*"
      ],
      "groupName": "Terraform Actions",
      "pinDigests": "false"
    },
    {
      "matchCategories": ["ci"],
      "matchDepNames": [
        "BlindfoldedSurgery/renovate-config",
        "BlindfoldedSurgery/actions-*",
        "BjoernPetersen/actions-*"
      ],
      "description": "Don't pin first-party actions",
      "rangeStrategy": "replace",
      "pinDigests": "false"
    },
    {
      "matchCategories": ["ci"],
      "matchDepNames": [
        "astral-sh/setup-uv",
        "jdx/mise-action",
        "docker/login-action"
      ],
      "description": "Don't pin digests for actions with immutable releases",
      "pinDigests": "false"
    },
    {
      "matchCategories": ["ci"],
      "matchDepNames": [
        "actions/checkout"
      ],
      "allowedVersions": "6.0.2"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "pypi",
      "fileMatch": [
        "^\\.github/workflows/.+\\.ya?ml$",
        "Dockerfile"
      ],
      "matchStrings": [
        "pipx? install (?<depName>[_\\-a-zA-Z]+)==(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/.+\\.ya?ml$"
      ],
      "matchStrings": [
        "renovate: datasource=(?<datasource>.+?) depName=(?<depName>.+?)(?: packageName=(?<packageName>.+?))?\\s[^:]+: ['\"]?(?<currentValue>.+?)['\"]?\\s"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/.+\\.ya?ml$"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "python",
      "matchStrings": [
        "python-version: ['\"]?(?<currentValue>.+?)['\"]?\\s"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^\\.github/workflows/.+\\.ya?ml$"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "debian",
      "matchStrings": [
        "debian-version: ['\"]?(?<currentValue>.+?)['\"]?\\s"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": [
        "Dockerfile"
      ],
      "matchStrings": [
        "renovate: type=git-digest repo=(?<packageName>.+/(?<depName>[^/]+/[^/]+))\\s(ENV|ARG) [A-Z_]+_VERSION=(?<currentDigest>.+)"
      ],
      "currentValueTemplate": "main",
      "datasourceTemplate": "git-refs"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "values.yaml"
      ],
      "matchStrings": [
        "renovate: datasource=(?<datasource>.+?)\\s.+?: (?<depName>[^:]+):(?<currentValue>.+)\\s"
      ]
    }
  ]
}
